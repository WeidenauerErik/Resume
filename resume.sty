% Minimal, ATS-friendly resume style: monochrome, single column, no
% graphics/icons. Small-caps section headings with a hairline rule below;
% each entry is plain flowing text (title \hfill date) rather than a
% table, so PDF text extraction stays in correct left-to-right order.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{resume}[2026/07/18 Minimal ATS-friendly resume style]

\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage[a4paper, top=0.45in, bottom=0.4in, left=0.55in, right=0.55in]{geometry}
\RequirePackage{titlesec}
\RequirePackage{enumitem}
\RequirePackage[hidelinks]{hyperref}

\pagestyle{empty}
\raggedbottom
\setlength{\parindent}{0pt}

% ---- Section headings ------------------------------------------------
\titleformat{\section}{\scshape\large}{}{0pt}{}[\vspace{-1pt}\titlerule\vspace{4pt}]
\titlespacing{\section}{0pt}{10pt}{2pt}

% ---- Tight bullet list, reused by every section ------------------------
\newlist{tightlist}{itemize}{1}
\setlist[tightlist]{nosep, leftmargin=1.1em, topsep=0pt, itemsep=2pt, label=\textbullet}

% ---- Entry environments -------------------------------------------------
% \begin{workentry}{Title}{Company}{Location}{Date range} \item ... \end{workentry}
\newenvironment{workentry}[4]{%
  \noindent\textbf{#1}\hfill\textbf{#4}\\
  #2\hfill\textit{#3}\\[-10pt]
  \begin{tightlist}
}{%
  \end{tightlist}\vspace{20pt}
}

% \begin{eduentry}{Institution}{Location}{Degree, Major}{Date range} \item ... \end{eduentry}
\newenvironment{eduentry}[4]{%
  \noindent\textbf{#1}\hfill\textbf{#2}\\
  #3\hfill#4\\[-10pt]
  \begin{tightlist}
}{%
  \end{tightlist}\vspace{20pt}
}

% \begin{projectentry}{Title (dates)}{Tech stack} \item ... \end{projectentry}
\newenvironment{projectentry}[2]{%
  \noindent\textbf{#1}\\
  {\small\itshape #2}\\[-10pt]
  \begin{tightlist}
}{%
  \end{tightlist}\vspace{20pt}
}

\endinput
